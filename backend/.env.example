# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_VERSION=1.0.0
APP_PORT=8080

# ── Database ───────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=apex
DB_PASSWORD=apex_dev_secret
DB_NAME=apex_trading
DB_SSLMODE=disable

# Full DSN — used directly by the migrate CLI tool
DB_DSN=postgres://apex:apex_dev_secret@localhost:5432/apex_trading?sslmode=disable

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev_secret

# ── JWT — generate with: make generate-secrets ────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_minimum_32_chars_!!
JWT_REFRESH_SECRET=change_me_refresh_secret_minimum_32_chars_!
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# ── Dev tools (pgAdmin + Redis Commander) ─────────────────────────────────────
PGADMIN_PASSWORD=pgadmin_dev
REDIS_UI_PASSWORD=admin
